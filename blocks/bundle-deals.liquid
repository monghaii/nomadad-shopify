{%- doc -%}
  Bundle / volume deal selector for the product page.
  "Buy more, save more" rows that add the selected variant to the cart at the
  chosen quantity. The percentage discount is enforced at checkout via a cart
  discount code, so this only handles quantity + messaging.
{%- enddoc -%}

{% liquid
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif
  assign variant = product.selected_or_first_available_variant
  assign unit_price = variant.price | default: 0

  assign quantities = '1,2,3' | split: ','
  assign discounts = '0,' | append: block.settings.tier_1_discount | append: ',' | append: block.settings.tier_2_discount | split: ','
%}

<bundle-deals
  class="bundle-deals spacing-style"
  data-section-id="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-unit-price="{{ unit_price }}"
  data-money-format="{{ shop.money_format | escape }}"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  {%- if block.settings.heading != blank -%}
    <p class="bundle-deals__title">🛒 {{ block.settings.heading }}</p>
  {%- endif -%}

  <div class="bundle-deals__rows">
    {%- for qty in quantities -%}
      {%- liquid
        assign q = qty | times: 1
        assign disc = discounts[forloop.index0] | times: 1
        assign gross = unit_price | times: q
        assign factor = 100 | minus: disc
        assign net = gross | times: factor | divided_by: 100
        assign is_popular = false
        if block.settings.popular_tier == q
          assign is_popular = true
        endif
        assign qty_label = 'Buy ' | append: q
        if forloop.last
          assign qty_label = qty_label | append: '+'
        endif
      -%}
      <button
        type="button"
        class="bundle-deals__option{% if is_popular %} bundle-deals__option--popular{% endif %}"
        data-quantity="{{ q }}"
        data-discount="{{ disc }}"
        aria-label="{% if disc > 0 %}Buy {{ q }}, save {{ disc }}%{% else %}Buy {{ q }}{% endif %}"
      >
        {%- if is_popular -%}
          <span class="bundle-deals__flag">🔥 {{ block.settings.popular_label }}</span>
        {%- endif -%}
        <span class="bundle-deals__left">
          <span class="bundle-deals__radio" aria-hidden="true">+</span>
          <span class="bundle-deals__qty">{{ qty_label }}</span>
          {%- if disc > 0 -%}
            <span class="bundle-deals__save">Save {{ disc }}%</span>
          {%- else -%}
            <span class="bundle-deals__save bundle-deals__save--muted">Standard</span>
          {%- endif -%}
        </span>
        <span class="bundle-deals__pricing">
          <span class="bundle-deals__price" data-bundle-net>{{ net | money }}</span>
          {%- if disc > 0 -%}
            <s class="bundle-deals__compare" data-bundle-gross>{{ gross | money }}</s>
          {%- endif -%}
        </span>
      </button>
    {%- endfor -%}
  </div>

  <p class="bundle-deals__error" data-bundle-error hidden></p>

  {%- if block.settings.disclaimer != blank -%}
    <p class="bundle-deals__disclaimer">{{ block.settings.disclaimer }}</p>
  {%- endif -%}
</bundle-deals>

<script
  src="{{ 'bundle-deals.js' | asset_url }}"
  defer
></script>

{% stylesheet %}
  .bundle-deals {
    display: block;
  }

  .bundle-deals__title {
    margin: 0 0 10px;
    font-weight: 700;
    font-size: var(--font-size--md);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .bundle-deals__rows {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .bundle-deals__option {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    width: 100%;
    padding: 14px 16px;
    border: 2px solid var(--color-border, #e5e4e2);
    border-radius: 14px;
    background: var(--color-background);
    color: var(--color-foreground);
    cursor: pointer;
    text-align: left;
    transition: border-color 0.12s ease, background-color 0.12s ease, box-shadow 0.12s ease;
  }

  .bundle-deals__option:hover {
    border-color: color-mix(in srgb, var(--color-primary, #356c38) 55%, transparent);
  }

  .bundle-deals__option:hover .bundle-deals__radio {
    border-color: var(--color-primary, #356c38);
    color: var(--color-primary, #356c38);
  }

  .bundle-deals__option:active {
    transform: scale(0.995);
  }

  .bundle-deals__option[aria-busy='true'] {
    opacity: 0.6;
    pointer-events: none;
  }

  .bundle-deals__option--popular {
    border-color: var(--color-primary, #356c38);
    background: color-mix(in srgb, var(--color-primary, #356c38) 6%, var(--color-background));
  }

  .bundle-deals__left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .bundle-deals__radio {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 2px solid var(--color-border, #d0cfcc);
    font-size: 15px;
    font-weight: 700;
    line-height: 1;
    color: var(--color-primary, #356c38);
    transition: all 0.12s ease;
  }

  .bundle-deals__option--popular .bundle-deals__radio {
    border-color: var(--color-primary, #356c38);
    background: var(--color-primary, #356c38);
    color: #fff;
  }

  .bundle-deals__qty {
    font-weight: 700;
    font-size: var(--font-size--md);
  }

  .bundle-deals__save {
    display: inline-block;
    padding: 2px 9px;
    border-radius: 40px;
    background: #dcfce7;
    color: #15803d;
    font-size: 0.6875rem;
    font-weight: 700;
  }

  .bundle-deals__save--muted {
    background: var(--color-border, #f1f0ee);
    color: var(--color-foreground);
    opacity: 0.65;
  }

  .bundle-deals__pricing {
    display: flex;
    align-items: baseline;
    gap: 8px;
    flex-shrink: 0;
  }

  .bundle-deals__price {
    font-weight: 800;
    font-size: var(--font-size--md);
  }

  .bundle-deals__compare {
    opacity: 0.5;
    font-size: 0.8125rem;
  }

  .bundle-deals__flag {
    position: absolute;
    top: -10px;
    right: 14px;
    white-space: nowrap;
    padding: 2px 10px;
    border-radius: 40px;
    background: #ef4444;
    color: #fff;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    box-shadow: 0 2px 6px rgba(239, 68, 68, 0.3);
  }

  .bundle-deals__error {
    margin: 10px 0 0;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #c0392b;
  }

  .bundle-deals__disclaimer {
    margin: 10px 0 0;
    font-size: 0.75rem;
    opacity: 0.65;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Bundle deals",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy more, save more"
    },
    {
      "type": "range",
      "id": "tier_1_discount",
      "label": "Buy 2 discount",
      "min": 0,
      "max": 90,
      "step": 1,
      "unit": "%",
      "default": 10
    },
    {
      "type": "range",
      "id": "tier_2_discount",
      "label": "Buy 3+ discount",
      "min": 0,
      "max": 90,
      "step": 1,
      "unit": "%",
      "default": 20
    },
    {
      "type": "range",
      "id": "popular_tier",
      "label": "Highlight quantity (0 = none)",
      "min": 0,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "text",
      "id": "popular_label",
      "label": "Highlight label",
      "default": "Most popular"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Discount applied automatically at checkout."
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Bundle deals"
    }
  ]
}
{% endschema %}
