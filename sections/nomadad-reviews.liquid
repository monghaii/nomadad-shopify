{%- liquid
  assign items = section.blocks
  assign rating = section.settings.rating | plus: 0.0
  assign full = rating | floor
  assign half_index = full | plus: 1
  assign has_half = false
  assign remainder = rating | minus: full
  if remainder >= 0.25
    assign has_half = true
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div id="reviews" class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} nmd-rv" data-testid="reviews-{{ section.id }}" style="--nmd-pt: {{ section.settings.padding-block-start }}px; --nmd-pb: {{ section.settings.padding-block-end }}px;">
  <div class="nmd-rv__head">
    <div>
      {%- if section.settings.eyebrow != blank -%}<span class="nmd-badge nmd-badge--amber">{{ section.settings.eyebrow }}</span>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="nmd-rv__title">{{ section.settings.heading }}</h2>{%- endif -%}
      <div class="nmd-rv__summary">
        <span class="nmd-rv__stars" aria-hidden="true">
          {%- for i in (1..5) -%}
            {%- if i <= full -%}<span class="nmd-star nmd-star--full">★</span>
            {%- elsif has_half and i == half_index -%}<span class="nmd-star nmd-star--half">★</span>
            {%- else -%}<span class="nmd-star nmd-star--empty">★</span>{%- endif -%}
          {%- endfor -%}
        </span>
        <span class="nmd-rv__summary-text">{{ rating }} out of 5 · {{ section.settings.review_count }}</span>
      </div>
    </div>
    {%- if section.settings.recommend_text != blank -%}
      <span class="nmd-rv__recommend">👍 {{ section.settings.recommend_text }}</span>
    {%- endif -%}
  </div>

  <div class="nmd-rv__grid">
    {%- for block in items -%}
      {%- liquid
        assign r = block.settings.rating | default: 5
      -%}
      <div class="nmd-rv__card" {{ block.shopify_attributes }}>
        <div class="nmd-rv__card-top">
          <span class="nmd-rv__stars nmd-rv__stars--sm" aria-hidden="true">
            {%- for i in (1..5) -%}
              {%- if i <= r -%}<span class="nmd-star nmd-star--full">★</span>{%- else -%}<span class="nmd-star nmd-star--empty">★</span>{%- endif -%}
            {%- endfor -%}
          </span>
          <span class="nmd-rv__date">{{ block.settings.date }}</span>
        </div>
        <h4 class="nmd-rv__card-title">{{ block.settings.title }}</h4>
        <p class="nmd-rv__body">{{ block.settings.body }}</p>
        <div class="nmd-rv__foot">
          <span class="nmd-rv__name">{{ block.settings.name }}</span>
          {%- if block.settings.verified -%}<span class="nmd-rv__verified">✓ Verified Buyer</span>{%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .nmd-badge { display: inline-block; padding: 4px 12px; border-radius: 40px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; }
  .nmd-badge--amber { background: #fef3c7; color: #b45309; }
  .nmd-rv { padding-block: var(--nmd-pt, 56px) var(--nmd-pb, 56px); }
  .nmd-rv__head { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 16px; margin-block-end: 36px; }
  .nmd-rv__title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; margin: 16px 0 8px; }
  .nmd-rv__summary { display: flex; align-items: center; gap: 8px; }
  .nmd-rv__stars { letter-spacing: 1px; font-size: 1.1rem; }
  .nmd-rv__stars--sm { font-size: 0.85rem; }
  .nmd-star--full { color: #fbbf24; }
  .nmd-star--empty { color: #e5e7eb; }
  .nmd-star--half { position: relative; color: #e5e7eb; }
  .nmd-star--half::before { content: "★"; position: absolute; left: 0; width: 50%; overflow: hidden; color: #fbbf24; }
  .nmd-rv__summary-text { font-size: 0.875rem; opacity: 0.7; }
  .nmd-rv__recommend {
    display: inline-flex; align-items: center; gap: 6px; white-space: nowrap;
    background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d;
    font-weight: 700; font-size: 0.85rem; padding: 8px 16px; border-radius: 40px;
  }
  .nmd-rv__grid { display: grid; gap: 16px; }
  @media screen and (min-width: 750px) { .nmd-rv__grid { grid-template-columns: repeat(2, 1fr); } }
  @media screen and (min-width: 990px) { .nmd-rv__grid { grid-template-columns: repeat(3, 1fr); } }
  .nmd-rv__card { background: var(--color-background); border: 1px solid var(--color-border); border-radius: 14px; padding: 20px; }
  .nmd-rv__card-top { display: flex; align-items: center; justify-content: space-between; margin-block-end: 8px; }
  .nmd-rv__date { font-size: 0.65rem; opacity: 0.45; }
  .nmd-rv__card-title { font-size: 0.9rem; font-weight: 700; margin: 0 0 4px; }
  .nmd-rv__body { font-size: 0.8rem; line-height: 1.55; opacity: 0.75; margin: 0 0 14px; }
  .nmd-rv__foot { display: flex; align-items: center; justify-content: space-between; padding-block-start: 10px; border-block-start: 1px solid var(--color-border); }
  .nmd-rv__name { font-size: 0.8rem; font-weight: 600; }
  .nmd-rv__verified { font-size: 0.65rem; font-weight: 700; color: var(--color-primary); }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer reviews",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-1" },
    { "type": "select", "id": "section_width", "label": "t:settings.width", "options": [ { "value": "page-width", "label": "t:options.page" }, { "value": "full-width", "label": "t:options.full" } ], "default": "page-width" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Social Proof" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Customer Reviews ⭐" },
    { "type": "text", "id": "rating", "label": "Average rating", "default": "4.0" },
    { "type": "text", "id": "review_count", "label": "Review count text", "default": "2,000+ reviews" },
    { "type": "text", "id": "recommend_text", "label": "Recommend text", "default": "94% would recommend" },
    { "type": "header", "content": "t:content.padding" },
    { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Marcus T." },
        { "type": "text", "id": "date", "label": "Date", "default": "2 weeks ago" },
        { "type": "range", "id": "rating", "label": "Stars", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "title", "label": "Title", "default": "Great product" },
        { "type": "textarea", "id": "body", "label": "Body", "default": "Loved it." },
        { "type": "checkbox", "id": "verified", "label": "Verified buyer", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer reviews",
      "category": "t:categories.storytelling",
      "blocks": [
        { "type": "review", "settings": { "name": "Marcus T.", "date": "2 weeks ago", "rating": 5, "title": "14-hour flight, slept 8 hours 😴", "body": "Used it on a flight to Tokyo. Slept 8 hours straight. My wife was jealous. The blanket sling is the real MVP.", "verified": true } },
        { "type": "review", "settings": { "name": "David K.", "date": "1 month ago", "rating": 5, "title": "Road trip game changer 🚗", "body": "Family road trips used to mean I'd arrive exhausted even as a passenger. Now I actually rest while my wife drives. Three kids in the back, still slept.", "verified": true } },
        { "type": "review", "settings": { "name": "James R.", "date": "3 weeks ago", "rating": 4, "title": "Great concept, solid execution", "body": "The blanket sling is the secret weapon. Keeps you from sliding around in your seat. Eye mask could be slightly softer but overall brilliant design.", "verified": true } },
        { "type": "review", "settings": { "name": "Sarah M.", "date": "1 week ago", "rating": 5, "title": "Bought for my husband ❤️", "body": "Got this for my husband who flies weekly for work. He says it's the best travel purchase he's ever made. Already ordered a second one for me.", "verified": true } },
        { "type": "review", "settings": { "name": "Tom B.", "date": "2 months ago", "rating": 4, "title": "Compact and effective", "body": "Fits easily in my laptop bag. The memory foam pillow is supportive without being bulky. Use it on my weekly commuter flights.", "verified": true } },
        { "type": "review", "settings": { "name": "Alex W.", "date": "5 days ago", "rating": 5, "title": "Why didn't this exist sooner?!", "body": "I've tried every neck pillow on Amazon. This is the first system that actually works because it addresses the whole body, not just the neck.", "verified": true } }
      ]
    }
  ]
}
{% endschema %}
