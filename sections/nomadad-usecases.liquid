{%- liquid
  assign items = section.blocks
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} nmd-usecases" data-testid="usecases-{{ section.id }}" style="--nmd-pt: {{ section.settings.padding-block-start }}px; --nmd-pb: {{ section.settings.padding-block-end }}px;">
  <div class="nmd-usecases__head">
    {%- if section.settings.eyebrow != blank -%}
      <span class="nmd-badge nmd-badge--moss">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="nmd-usecases__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="nmd-usecases__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="nmd-usecases__grid">
    {%- for block in items -%}
      <div class="nmd-usecase" {{ block.shopify_attributes }}>
        <div class="nmd-usecase__emoji">{{ block.settings.emoji }}</div>
        <h3 class="nmd-usecase__title">{{ block.settings.title }}</h3>
        <p class="nmd-usecase__desc">{{ block.settings.description }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .nmd-usecases { padding-block: var(--nmd-pt, 56px) var(--nmd-pb, 56px); }
  .nmd-usecases__head { text-align: center; max-width: 640px; margin-inline: auto; margin-block-end: 40px; }
  .nmd-badge {
    display: inline-block; padding: 4px 12px; border-radius: 40px;
    font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em;
  }
  .nmd-badge--moss { background: color-mix(in srgb, var(--color-primary) 12%, transparent); color: var(--color-primary); }
  .nmd-badge--red { background: #fef2f2; color: #dc2626; }
  .nmd-badge--amber { background: #fef3c7; color: #b45309; }
  .nmd-badge--blue { background: #eff6ff; color: #2563eb; }
  .nmd-usecases__title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; margin: 16px 0 8px; }
  .nmd-usecases__sub { opacity: 0.7; margin: 0; }
  .nmd-usecases__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px;
  }
  @media screen and (min-width: 990px) { .nmd-usecases__grid { grid-template-columns: repeat(4, 1fr); } }
  .nmd-usecase {
    background: var(--color-background); border: 1px solid var(--color-border);
    border-radius: 18px; padding: 22px 18px; text-align: center;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
  }
  .nmd-usecase:hover {
    border-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
    box-shadow: 0 10px 30px rgba(0,0,0,0.06); transform: translateY(-2px);
  }
  .nmd-usecase__emoji { font-size: 2rem; margin-block-end: 12px; }
  .nmd-usecase__title { font-size: 0.95rem; font-weight: 700; margin: 0 0 4px; }
  .nmd-usecase__desc { font-size: 0.8125rem; opacity: 0.65; margin: 0; line-height: 1.5; }
{% endstylesheet %}

{% schema %}
{
  "name": "Use cases",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-3" },
    { "type": "select", "id": "section_width", "label": "t:settings.width", "options": [ { "value": "page-width", "label": "t:options.page" }, { "value": "full-width", "label": "t:options.full" } ], "default": "page-width" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Works Everywhere" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for Every Mile 🛣️" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "From red-eyes to road trips — this kit has your back (and your neck)." },
    { "type": "header", "content": "t:content.padding" },
    { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "usecase",
      "name": "Use case",
      "settings": [
        { "type": "text", "id": "emoji", "label": "Emoji", "default": "✈️" },
        { "type": "text", "id": "title", "label": "Title", "default": "Long-Haul Flights" },
        { "type": "text", "id": "description", "label": "Description", "default": "Sleep like first class in economy." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Use cases",
      "category": "t:categories.storytelling",
      "blocks": [
        { "type": "usecase", "settings": { "emoji": "✈️", "title": "Long-Haul Flights", "description": "Sleep like first class in economy." } },
        { "type": "usecase", "settings": { "emoji": "🚗", "title": "Road Trips", "description": "Passenger seat naps, no neck pain." } },
        { "type": "usecase", "settings": { "emoji": "☕", "title": "Airport Layovers", "description": "Turn any gate seat into a bed." } },
        { "type": "usecase", "settings": { "emoji": "🌙", "title": "Red-Eye Recovery", "description": "Land feeling human, not zombie." } }
      ]
    }
  ]
}
{% endschema %}
