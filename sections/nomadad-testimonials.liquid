{%- liquid
  assign items = section.blocks
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div class="section section--{{ section.settings.section_width }} color-{{ section.settings.color_scheme }} nmd-tst" data-testid="testimonials-{{ section.id }}" style="--nmd-pt: {{ section.settings.padding-block-start }}px; --nmd-pb: {{ section.settings.padding-block-end }}px;">
  <div class="nmd-tst__head">
    {%- if section.settings.eyebrow != blank -%}
      <span class="nmd-badge nmd-badge--amber">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="nmd-tst__title">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="nmd-tst__sub">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </div>

  <div class="nmd-tst__grid">
    {%- for block in items -%}
      <div class="nmd-tst__card" {{ block.shopify_attributes }}>
        <div class="nmd-tst__stars">★★★★★</div>
        <p class="nmd-tst__quote">“{{ block.settings.quote }}”</p>
        <div class="nmd-tst__foot">
          <span class="nmd-tst__avatar">{{ block.settings.name | slice: 0 }}</span>
          <span class="nmd-tst__meta">
            <span class="nmd-tst__name">{{ block.settings.name }}</span>
            <span class="nmd-tst__trip">📍 {{ block.settings.trip }}</span>
          </span>
          <span class="nmd-tst__verified">✓ Verified</span>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .nmd-badge { display: inline-block; padding: 4px 12px; border-radius: 40px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; }
  .nmd-badge--amber { background: #fef3c7; color: #b45309; }
  .nmd-tst { padding-block: var(--nmd-pt, 56px) var(--nmd-pb, 56px); }
  .nmd-tst__head { text-align: center; margin-block-end: 40px; }
  .nmd-tst__title { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; margin: 16px 0 8px; }
  .nmd-tst__sub { opacity: 0.65; margin: 0; font-size: 0.9rem; }
  .nmd-tst__grid { display: grid; gap: 20px; }
  @media screen and (min-width: 750px) { .nmd-tst__grid { grid-template-columns: repeat(3, 1fr); } }
  .nmd-tst__card {
    background: var(--color-background); border: 1px solid var(--color-border);
    border-radius: 20px; padding: 26px; box-shadow: 0 1px 2px rgba(0,0,0,0.04);
  }
  .nmd-tst__stars { color: #fbbf24; letter-spacing: 2px; margin-block-end: 12px; }
  .nmd-tst__quote { font-size: 0.9rem; line-height: 1.6; margin: 0 0 18px; }
  .nmd-tst__foot { display: flex; align-items: center; gap: 12px; padding-block-start: 16px; border-block-start: 1px solid var(--color-border); }
  .nmd-tst__avatar {
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    width: 36px; height: 36px; border-radius: 50%; font-weight: 700; font-size: 0.85rem;
    background: color-mix(in srgb, var(--color-primary) 12%, transparent); color: var(--color-primary);
  }
  .nmd-tst__meta { display: flex; flex-direction: column; line-height: 1.3; }
  .nmd-tst__name { font-weight: 700; font-size: 0.85rem; }
  .nmd-tst__trip { font-size: 0.72rem; opacity: 0.55; }
  .nmd-tst__verified { margin-inline-start: auto; font-size: 0.68rem; font-weight: 700; color: var(--color-primary); white-space: nowrap; }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "t:settings.color_scheme", "default": "scheme-3" },
    { "type": "select", "id": "section_width", "label": "t:settings.width", "options": [ { "value": "page-width", "label": "t:options.page" }, { "value": "full-width", "label": "t:options.full" } ], "default": "page-width" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real Stories" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Happy Travelers Love NomaDad ❤️" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Real dads, real trips, real rest." },
    { "type": "header", "content": "t:content.padding" },
    { "type": "range", "id": "padding-block-start", "label": "t:settings.top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding-block-end", "label": "t:settings.bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 56 }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Mike S." },
        { "type": "text", "id": "trip", "label": "Trip", "default": "LAX → Tokyo" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "Slept 8 hours straight in economy. Best money I've spent on travel gear." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "category": "t:categories.storytelling",
      "blocks": [
        { "type": "testimonial", "settings": { "name": "Mike S.", "trip": "LAX → Tokyo", "quote": "Slept 8 hours straight in economy. My wife couldn't believe it. Best $50 I've ever spent on travel gear." } },
        { "type": "testimonial", "settings": { "name": "Chris P.", "trip": "12hr family road trip", "quote": "When it wasn't my turn to drive, I actually rested instead of just closing my eyes and pretending." } },
        { "type": "testimonial", "settings": { "name": "Jason L.", "trip": "Weekly business flights", "quote": "I fly every Monday. This kit is the reason I don't dread it anymore. Game. Changer." } }
      ]
    }
  ]
}
{% endschema %}
