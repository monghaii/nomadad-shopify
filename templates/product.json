      "type": "nomadad-faq",
      "blocks": {
        "f1": {
          "type": "faq",
          "settings": {
            "question": "Will this fit in my carry-on?",
            "answer": "Absolutely! The entire kit packs into its own pouch — about the size of a water bottle. It clips to the outside of your bag too. ✈️"
          }
        },
        "f2": {
          "type": "faq",
          "settings": {
            "question": "Is the neck pillow inflatable?",
            "answer": "Nope — it's memory foam! No pumping, no valves, no popping mid-flight. Just pull it out and it's ready in seconds."
          }
        },
        "f3": {
          "type": "faq",
          "settings": {
            "question": "Can I wash it?",
            "answer": "Yes! All components are machine washable. Remove the memory foam insert, toss the covers in on a gentle cycle, and air dry. 🧼"
          }
        },
        "f4": {
          "type": "faq",
          "settings": {
            "question": "Does the blanket sling actually work?",
            "answer": "That's the magic. It wraps around your torso and the seat, creating gentle resistance that keeps you upright — like a cozy seatbelt for sleeping. 💤"
          }
        },
        "f5": {
          "type": "faq",
          "settings": {
            "question": "What if I wear glasses?",
            "answer": "No problem! The eye mask has a low-profile nose bridge that works whether your glasses are on or pushed up on your head."
          }
        },
        "f6": {
          "type": "faq",
          "settings": {
            "question": "Is this just for planes?",
